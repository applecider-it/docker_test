{
  "compilerOptions": {
    "target": "es2020",
    "module": "es2020",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "baseUrl": "./resources/js",
    "paths": {
      "@/*": ["*"]
    },
    "allowSyntheticDefaultImports": true
  }
}
